// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserModel {
  id         Int             @id @default(autoincrement())
  email      String          @unique
  password   String
  name       String
  role       Role            @default(USER)
  accounts   AccountModel[]
  categories CategoryModel[]
}

model AccountModel {
  id              Int              @id @default(autoincrement())
  name            String
  currency        CurrencyModel    @relation(fields: [currencyModelId], references: [id])
  UserModel       UserModel        @relation(fields: [userModelId], references: [id])
  userModelId     Int
  OperationModel  OperationModel[]
  currencyModelId Int
}

model CategoryModel {
  id             Int              @id @default(autoincrement())
  name           String
  UserModel      UserModel        @relation(fields: [userModelId], references: [id])
  userModelId    Int
  OperationModel OperationModel[]
}

model OperationModel {
  id              Int           @id @default(autoincrement())
  balance         Float
  sum             Float
  createdAt       DateTime      @default(now())
  account         AccountModel  @relation(fields: [accountModelId], references: [id])
  accountModelId  Int
  type            OperationType @default(EXPENSE)
  comment         CommentModel? @relation(fields: [commentModelId], references: [id])
  commentModelId  Int?
  category        CategoryModel @relation(fields: [categoryModelId], references: [id])
  categoryModelId Int
}

model CommentModel {
  id             Int              @id @default(autoincrement())
  text           String
  OperationModel OperationModel[]
}

model CurrencyModel {
  id           Int            @id @default(autoincrement())
  code         String         @unique
  AccountModel AccountModel[]
}

enum OperationType {
  INCOME
  EXPENSE
  TRANSFER
}

enum Role {
  ADMIN
  USER
}
